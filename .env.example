# 数据库配置
DATABASE_URL=postgresql+asyncpg://blog:blog123@db:5432/blog
REDIS_URL=redis://redis:6379/0

# 安全配置（生产环境请修改）
SECRET_KEY=your-super-secret-key-change-in-production-min-32-char
ALGORITHM=HS256
ACCESS_token_expire_minutes=60* * 24小时
refresh_token_expire_days=7

# 文件上传配置
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760  # 10MB
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp

# CORS 配置（前后端地址）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

